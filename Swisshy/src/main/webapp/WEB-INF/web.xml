<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Swisshy</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
   
    <!-- login -->
    <servlet>
        <servlet-name>loginServlet</servlet-name>
        <servlet-class>com.tap.servlet.loginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>loginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- register -->
    <servlet>
        <servlet-name>RegistrationServlet</servlet-name>
        <servlet-class>com.tap.servlet.RegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistrationServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- restaurant -->
    <servlet>
        <servlet-name>RestaurantServlet</servlet-name>
        <servlet-class>com.tap.servlet.RestaurantServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RestaurantServlet</servlet-name>
        <url-pattern>/restaurant</url-pattern>
    </servlet-mapping>

    <!-- menu -->
    <servlet>
        <servlet-name>MenuServlet</servlet-name>
        <servlet-class>com.tap.servlet.MenuServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MenuServlet</servlet-name>
        <url-pattern>/menu</url-pattern>
    </servlet-mapping>

    <!-- cart  ← ADD THIS -->
    <servlet>
        <servlet-name>CartServlet</servlet-name>
        <servlet-class>com.tap.servlet.CartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CartServlet</servlet-name>
        <url-pattern>/cart</url-pattern>
    </servlet-mapping>

    <!-- checkout -->
    <servlet>
        <servlet-name>CheckoutServlet</servlet-name>
        <servlet-class>com.tap.servlet.CheckoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckoutServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
    </servlet-mapping>

    <!-- logout -->
    <servlet>
        <servlet-name>logoutServlet</servlet-name>
        <servlet-class>com.tap.servlet.logoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>logoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    <servlet>
    <servlet-name>RestaurantAdminServlet</servlet-name>
    <servlet-class>com.tap.servlet.RestaurantAdminServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>RestaurantAdminServlet</servlet-name>
    <url-pattern>/restaurantAdmin</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>DeliveryServlet</servlet-name>
    <servlet-class>com.tap.servlet.DeliveryServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>DeliveryServlet</servlet-name>
    <url-pattern>/delivery</url-pattern>
</servlet-mapping>


</web-app>